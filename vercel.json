{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/pipeline/news-ingest?tiers=1,2",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/pipeline/news-ingest?tiers=3,4,5",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/pipeline/news-ingest?tiers=6",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/pipeline/news-process",
      "schedule": "30 */2 * * *"
    },
    {
      "path": "/api/pipeline/newsletter-send",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/pipeline/outreach-send?cap=25",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/pipeline/outreach-send?cap=50",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/pipeline/outreach-monitor",
      "schedule": "15 * * * *"
    }
  ]
}
